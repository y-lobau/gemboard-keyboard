<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="14dp"
    android:paddingTop="10dp"
    android:paddingEnd="14dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:id="@+id/keyboardSurface"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/keyboard_surface_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <LinearLayout
            android:id="@+id/waveContainer"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal">

            <View
                android:layout_width="6dp"
                android:layout_height="12dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/keyboard_wave_bar_background" />

            <View
                android:layout_width="6dp"
                android:layout_height="18dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/keyboard_wave_bar_background" />

            <View
                android:layout_width="6dp"
                android:layout_height="26dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/keyboard_wave_bar_background" />

            <View
                android:layout_width="6dp"
                android:layout_height="36dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/keyboard_wave_bar_background" />

            <View
                android:layout_width="6dp"
                android:layout_height="46dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/keyboard_wave_bar_background" />

            <View
                android:layout_width="6dp"
                android:layout_height="36dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/keyboard_wave_bar_background" />

            <View
                android:layout_width="6dp"
                android:layout_height="26dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/keyboard_wave_bar_background" />

            <View
                android:layout_width="6dp"
                android:layout_height="18dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/keyboard_wave_bar_background" />

            <View
                android:layout_width="6dp"
                android:layout_height="12dp"
                android:background="@drawable/keyboard_wave_bar_background" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="140dp"
            android:layout_height="40dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/keyboard_utility_tray_background"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="6dp"
            android:paddingTop="6dp"
            android:paddingEnd="6dp"
            android:paddingBottom="6dp">

            <ImageButton
                android:id="@+id/deleteButton"
                android:layout_width="38dp"
                android:layout_height="28dp"
                android:background="@drawable/keyboard_key_background"
                android:contentDescription="@string/plyn_delete_button"
                android:gravity="center"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="7dp"
                android:paddingVertical="5dp"
                android:scaleType="fitCenter"
                android:src="@drawable/keyboard_ic_delete"
                android:tint="#191C23" />

            <ImageButton
                android:id="@+id/spaceButton"
                android:layout_width="44dp"
                android:layout_height="28dp"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                android:background="@drawable/keyboard_key_background"
                android:contentDescription="@string/plyn_space_button"
                android:gravity="center"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="6dp"
                android:paddingVertical="6dp"
                android:scaleType="centerInside"
                android:src="@drawable/keyboard_ic_space"
                android:tint="#191C23" />

            <ImageButton
                android:id="@+id/enterButton"
                android:layout_width="38dp"
                android:layout_height="28dp"
                android:background="@drawable/keyboard_key_background"
                android:contentDescription="@string/plyn_enter_button"
                android:gravity="center"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="7dp"
                android:paddingVertical="5dp"
                android:scaleType="fitCenter"
                android:src="@drawable/keyboard_ic_return"
                android:tint="#191C23" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/speechButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/keyboard_mic_button_background"
            android:contentDescription="@string/plyn_speech_button"
            android:padding="14dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_btn_speak_now"
            android:tint="#141519" />
    </LinearLayout>

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:textColor="#3C4836"
        android:textSize="13sp" />

</LinearLayout>
