<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/keyboard_surface_background"
    android:orientation="vertical"
    android:paddingStart="10dp"
    android:paddingTop="10dp"
    android:paddingEnd="10dp"
    android:paddingBottom="8dp">

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="6dp"
        android:paddingBottom="8dp"
        android:textColor="#2D3138"
        android:textSize="13sp" />

    <Button
        android:id="@+id/speechButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/keyboard_action_key_background"
        android:text="Hold to speak"
        android:textAllCaps="false"
        android:textColor="#FFF7ED" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/deleteButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/keyboard_key_background"
            android:text="delete"
            android:textAllCaps="false"
            android:textColor="#1E2126" />

        <Button
            android:id="@+id/spaceButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="6dp"
            android:layout_weight="2"
            android:background="@drawable/keyboard_key_background"
            android:text="space"
            android:textAllCaps="false"
            android:textColor="#1E2126" />

        <Button
            android:id="@+id/enterButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/keyboard_key_background"
            android:text="enter"
            android:textAllCaps="false"
            android:textColor="#1E2126" />
    </LinearLayout>

</LinearLayout>
